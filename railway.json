{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node --enable-source-maps ./dist/index.mjs",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000,
    "healthchecks": {
      "cpu": {
        "percentage": 80
      },
      "memory": {
        "percentage": 80
      }
    }
  }
}
