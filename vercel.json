{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && cd artifacts/study-system && pnpm run build",
  "outputDirectory": "artifacts/study-system/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  }
}
